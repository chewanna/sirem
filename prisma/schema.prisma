// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PersonalMilitar {
  id_personal_militar Int       @id @default(autoincrement())
  matricula           String    @unique
  curp                String?   @unique
  rfc                 String?   @unique
  nombre              String
  apellido_paterno    String
  apellido_materno    String?
  fecha_nacimiento    DateTime?
  sexo                String?
  estado_civil        String?
  foto_url            String?

  // Foreign Keys
  id_grado          Int?
  id_arma_servicio  Int?
  id_organismo      Int? // Unidad/Adscripcion actual
  id_zona_militar   Int?
  id_region_militar Int?

  // Relations
  grado          CatGrado?         @relation(fields: [id_grado], references: [id_grado])
  arma_servicio  CatArmaServicio?  @relation(fields: [id_arma_servicio], references: [id_arma_servicio])
  organismo      CatOrganismo?     @relation(fields: [id_organismo], references: [id_organismo])
  zona_militar   CatZonaMilitar?   @relation(fields: [id_zona_militar], references: [id_zona_militar])
  region_militar CatRegionMilitar? @relation(fields: [id_region_militar], references: [id_region_militar])

  historial_ascensos    HistorialAscensos[]
  historial_adscripcion HistorialAdscripcion[]
  cargos                Cargo[]
  movimientos           Movimiento[]
  familiares            Familiar[]
  familiares_propios    FamiliarMilitar[]      @relation("PersonalFamiliares")
  familiar_de           FamiliarMilitar[]      @relation("FamiliarDe")
  conductas             Conducta[]

  fecha_ingreso     DateTime?
  fecha_empleo      DateTime?
  fecha_grado       DateTime?
  situacion         String?
  lugar_nacimiento  String?
  estado_nacimiento String?
  domicilio         String?
  telefono          String?
  email             String?
  especialidad      String?
  profesion         String?

  @@map("personal_militar")
}

model CatGrado {
  id_grado     Int                 @id @default(autoincrement())
  nombre_grado String
  abreviatura  String?
  personal     PersonalMilitar[]
  ascensos     HistorialAscensos[]

  @@map("cat_grado")
}

model CatArmaServicio {
  id_arma_servicio Int               @id @default(autoincrement())
  nombre_servicio  String
  personal         PersonalMilitar[]

  @@map("cat_arma_servicio")
}

model CatRegionMilitar {
  id_region_militar     Int               @id @default(autoincrement())
  nombre_region_militar String
  numero_region_militar String?
  personal              PersonalMilitar[]
  organismos            CatOrganismo[]

  @@map("cat_region_militar")
}

model CatZonaMilitar {
  id_zona_militar     Int               @id @default(autoincrement())
  nombre_zona_militar String
  numero_zona_militar String?
  personal            PersonalMilitar[]

  @@map("cat_zona_militar")
}

model CatOrganismo {
  id_organismo     Int     @id @default(autoincrement())
  nombre_organismo String
  tipo_organismo   String?
  campo_militar    String?

  id_region_militar Int?
  region            CatRegionMilitar? @relation(fields: [id_region_militar], references: [id_region_militar])

  personal              PersonalMilitar[]
  historial_adscripcion HistorialAdscripcion[]

  @@map("cat_organismo")
}

model HistorialAscensos {
  id_historial_ascenso Int      @id @default(autoincrement())
  id_personal_militar  Int
  id_grado             Int
  fecha_ascenso        DateTime

  personal PersonalMilitar @relation(fields: [id_personal_militar], references: [id_personal_militar])
  grado    CatGrado        @relation(fields: [id_grado], references: [id_grado])

  @@map("historial_ascensos")
}

model HistorialAdscripcion {
  id_adscripcion      Int       @id @default(autoincrement())
  id_personal_militar Int
  id_organismo        Int
  fecha_inicio        DateTime
  fecha_fin           DateTime?

  personal  PersonalMilitar @relation(fields: [id_personal_militar], references: [id_personal_militar])
  organismo CatOrganismo    @relation(fields: [id_organismo], references: [id_organismo])

  @@map("historial_adscripcion")
}

model Cargo {
  id_cargo            Int      @id @default(autoincrement())
  id_personal_militar Int
  grado               String
  fecha_cargo         DateTime
  cargo               String
  unidad              String
  ubicacion           String?

  personal PersonalMilitar @relation(fields: [id_personal_militar], references: [id_personal_militar])

  @@map("cargo")
}

model Movimiento {
  id_movimiento       Int       @id @default(autoincrement())
  id_personal_militar Int
  fecha_mov           DateTime
  tipo                String
  grado               String
  unidad              String
  situacion           String?
  // newly added
  motivo_movimiento   String?
  cargo               String?
  zm                  String?
  rm                  String?
  no_documento        String?
  fecha_documento     DateTime?
  no_acuerdo          String?
  motivo_detallado    String?

  personal PersonalMilitar @relation(fields: [id_personal_militar], references: [id_personal_militar])

  @@map("movimiento")
}

model Familiar {
  id_familiar         Int       @id @default(autoincrement())
  id_personal_militar Int
  tipo                String
  nombre              String
  parentesco          String
  fecha_nacimiento    DateTime?
  edad                Int?
  militar             Boolean   @default(false)
  grado               String?
  curp                String?
  matricula           String?

  personal PersonalMilitar @relation(fields: [id_personal_militar], references: [id_personal_militar])

  @@map("familiar")
}

model FamiliarMilitar {
  id_familiar_militar Int    @id @default(autoincrement())
  id_personal_militar Int
  id_familiar         Int
  parentesco          String
  id_usuario          Int?

  personal PersonalMilitar @relation("PersonalFamiliares", fields: [id_personal_militar], references: [id_personal_militar])
  familiar PersonalMilitar @relation("FamiliarDe", fields: [id_familiar], references: [id_personal_militar])
  usuario  Usuario?        @relation(fields: [id_usuario], references: [id_usuario])

  @@unique([id_personal_militar, id_familiar])
  @@map("familiar_militar")
}

model Listado {
  id_listado Int               @id @default(autoincrement())
  nombre     String
  fecha      DateTime          @default(now())
  personal   ListadoPersonal[]

  @@map("listado")
}

model ListadoPersonal {
  id                  Int @id @default(autoincrement())
  id_listado          Int
  id_personal_militar Int
  orden               Int @default(0)

  listado Listado @relation(fields: [id_listado], references: [id_listado], onDelete: Cascade)

  @@map("listado_personal")
}

model Conducta {
  id_conducta         Int      @id @default(autoincrement())
  id_personal_militar Int
  tipo                String // EXCELENTE | BUENA | REGULAR | MALA
  descripcion         String
  fecha               DateTime @default(now())

  personal PersonalMilitar @relation(fields: [id_personal_militar], references: [id_personal_militar], onDelete: Cascade)

  @@map("conducta")
}

model Subseccion {
  id_subseccion Int       @id @default(autoincrement())
  nombresubsec  String
  grupos        Grupo[]
  mesas         Mesa[]
  usuarios      Usuario[]

  @@map("subsecciones")
}

model Grupo {
  grupo_id    Int        @id @default(autoincrement())
  nombregrupo String
  subsecc     Int
  subseccion  Subseccion @relation(fields: [subsecc], references: [id_subseccion])
  mesas       Mesa[]
  usuarios    Usuario[]

  @@map("grupos")
}

model Mesa {
  mesa_id    Int     @id @default(autoincrement())
  nombremesa String
  abreviado  String?
  grupopert  Int
  subsecpert Int
  clase      String?

  grupo      Grupo      @relation(fields: [grupopert], references: [grupo_id])
  subseccion Subseccion @relation(fields: [subsecpert], references: [id_subseccion])
  usuarios   Usuario[]

  @@map("mesas")
}

model Role {
  id_role     Int       @id @default(autoincrement())
  nombre_role String    @unique // ADMINISTRADOR, DISCIPLINA_OFICIALES, USUARIO_REGULAR
  usuarios    Usuario[]

  @@map("roles")
}

model Usuario {
  id_usuario Int     @id @default(autoincrement())
  username   String  @unique
  password   String
  nombre     String?
  id_role    Int
  id_mesa    Int?
  id_grupo   Int?
  id_subsec  Int?
  session_id String?
  activo     Boolean @default(true)

  role                   Role              @relation(fields: [id_role], references: [id_role])
  mesa                   Mesa?             @relation(fields: [id_mesa], references: [mesa_id])
  grupo                  Grupo?            @relation(fields: [id_grupo], references: [grupo_id])
  subseccion             Subseccion?       @relation(fields: [id_subsec], references: [id_subseccion])
  familiares_registrados FamiliarMilitar[]

  @@map("usuarios")
}
